# Database
DB_HOST=localhost
DB_USER=bottrade
DB_PASS=your_secure_password
DB_NAME=bottrade

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Security (REQUIRED - no defaults)
JWT_SECRET=generate-a-random-64-char-string
ENCRYPTION_KEY=generate-a-random-32-char-string

# Clerk Auth (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_Z2xhZC10YWhyLTg1LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_PUBLISHABLE_KEY=pk_test_Z2xhZC10YWhyLTg1LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_Evy638z55cbAjUgtRAwbnsScJfLdPIiyTpYfv8NDlG

# Exchange provider: binance or bybit
EXCHANGE_PROVIDER=binance

# Binance (optional - for custom endpoints)
# BINANCE_WS_URL=wss://fstream.binance.com/stream
# BINANCE_REST_URL=https://fapi.binance.com

# Binance testnet mode (set to 'false' for production mainnet)
BINANCE_TESTNET=true

# Bybit (used when EXCHANGE_PROVIDER=bybit)
# BYBIT_TESTNET=false
# BYBIT_REST_URL=https://api.bybit.com
# BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
# BYBIT_CATEGORY=linear

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# FROM_EMAIL=noreply@bottrade.com
# APP_URL=https://bottrade.com

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TRADER=price_...
# Stripe annual prices (optional)
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_TRADER_ANNUAL=price_...
# STRIPE_TRIAL_DAYS=7

# Logging
LOG_LEVEL=info
