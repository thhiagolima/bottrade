# Domain
DOMAIN=gamingbr.pro
APP_URL=https://gamingbr.pro
APP_HTTP_PORT=8088

# Database
DB_NAME=bottrade
DB_PASS=change-this-long-random-password

# Security
# Generate with:
# openssl rand -hex 64
JWT_SECRET=change-this-64-plus-char-random-secret
# openssl rand -hex 32
ENCRYPTION_KEY=change-this-32-plus-char-random-secret

# Clerk Auth
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me

# Exchange
EXCHANGE_PROVIDER=binance
BINANCE_TESTNET=false

# Optional integrations
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@gamingbr.pro
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TRADER=

LOG_LEVEL=info

# Sentry (optional)
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DEBUG_ROUTE=false
# VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.25

# Grafana Cloud Loki via Grafana Alloy (optional)
# GRAFANA_CLOUD_LOKI_URL=https://logs-prod-000.grafana.net/loki/api/v1/push
# GRAFANA_CLOUD_LOKI_USERNAME=123456
# GRAFANA_CLOUD_LOKI_TOKEN=glc_...
